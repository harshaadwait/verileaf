# VeriLeaf Environment Configuration
# Copy to .env and fill in values

# Database (MUST deploy to ca-central-1 in production)
VERILEAF_DATABASE_URL=postgresql+asyncpg://verileaf:verileaf@db:5432/verileaf

# Redis
VERILEAF_REDIS_URL=redis://redis:6379/0
VERILEAF_CELERY_BROKER_URL=redis://redis:6379/1

# Greenline POS
VERILEAF_GREENLINE_BASE_URL=https://api.getgreenline.co/v1
VERILEAF_GREENLINE_WEBHOOK_SECRET=

# Encryption — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VERILEAF_FERNET_KEY=

# Compliance tuning
VERILEAF_RECONCILIATION_TOLERANCE_GRAMS=0.5
VERILEAF_MIDNIGHT_CRON_HOUR=23
VERILEAF_MIDNIGHT_CRON_MINUTE=59
